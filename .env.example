# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/artifact_archive"

# Base URL used when generating QR codes (must be reachable by phones scanning them).
# For local testing use http://localhost:3000
# For on-site use your machine's LAN IP, e.g. http://192.168.1.20:3000
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
